!cpu 6502
!to "build/DEMO/NIGHT.STALKER#06BD00",plain
*=$BD00

         !source "src/constants.a"   ; no code in these
         !source "src/macros.a"


         +ENABLE_ACCEL_LC
         +LOAD_XSINGLE title
         lda   #$60
         sta   $5BD5
         sta   $5C0C
         jsr   $800
         lda   #$92
         sta   $0D
         lda   #$C4
         sta   $0C
         lda   #$40
         sta   $0F
         stx   $0E
         jsr   $637
         lda   $c057
         lda   $c052
         lda   $c050
         ldx   #$C0
         txs
         ldx   #x_e - x_b
-        lda   x_b - 1, x
         sta   $1C0,x
         dex
         bne   -
         jmp   $1C1
x_b !pseudopc $1C1 {
         jsr   $610
         lda   #$D0
         sta   $0DEF
         sta   $1DC5
         sta   $ABC9
         sta   $AC6E
         sta   $B765
         ldx   #3-1
-        lda   patch,x
         sta   $18E5,x
         sta   $196D,x
         dex
         bpl   -
         ldx   #7-1
-        lda   patch2,x
         sta   $BB5B,x
         dex
         bpl   -
         +DISABLE_ACCEL
         jmp   $6000

patch2   !byte $00,$C0,$10,$05
patch    !byte $4C,$00,$01

  !if * > $282 {
    !error "code is too large, ends at ", *
  }
}
x_e

title    +PSTRING "NIGHT.STALKER"
