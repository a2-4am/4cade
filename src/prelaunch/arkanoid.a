!cpu 6502
!to "build/PRELAUNCH.INDEXED/ARKANOID",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$60
         sta   $5DDB
         jsr   $1E00

         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$b5
         sta   $145c
         sta   $1d65
+
         jsr   DisableAccelerator
         jsr   HideLaunchArtworkLC2
         sta   $C05F      ; fix //c and //c+ HGR color

         +LC_REBOOT
         lda   #$2C
         sta   $600
         sta   $603       ; BIT changing reset

         ldy   #0
         tya
         jmp   $5DDC

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
