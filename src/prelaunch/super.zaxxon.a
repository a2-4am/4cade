!cpu 6502
!to "build/PRELAUNCH.INDEXED/SUPER.ZAXXON",plain
*=$106

    !source "src/macros.a"

         +READ_RAM2_WRITE_RAM2
         +FORCE_REBOOT
         lda   MachineStatus
         +READ_ROM_NO_WRITE
         and   #CHEATS_ENABLED
         beq   +
         lda   #0
         sta   $21C2
         lda   #$71
         sta   $21C3
         ldy   #(callback_e - callback) - 1
-        lda   callback, y
         sta   $7100, y
         dey
         bpl   -
+
         ldx   #(hide_callback_e-hide_callback)-1
-        lda   hide_callback, x
         sta   $109, x
         dex
         bpl   -
         ldx   #$09
         stx   $21CE
         +READ_RAM2_NO_WRITE
-        lda   HideLaunchArtworkLC2 - 1, x
         sta   hide_artwork - 1, x
         dex
         bne   -
         +READ_ROM_NO_WRITE
         inx
         stx   $21CF
         jmp   $2000      ; decompress

callback !pseudopc $7100 {
         jsr   $415
         lda   #$bd
         sta   $1999      ; patch - don't decrease lives
         rts
}
callback_e

hide_callback !pseudopc $109 {
         sty   $BFDC
         ldx   #$0D
         jsr   $193
         jsr   hide_artwork
         jmp   $56C4
hide_artwork
HideArtworkCallback
}
hide_callback_e

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
