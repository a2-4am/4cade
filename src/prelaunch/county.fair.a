!cpu 6502
!to "build/PRELAUNCH.INDEXED/COUNTY.FAIR",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $951D
         jsr   $6690      ; decompress

         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$a5
         sta   $1060      ; patch - don't decrease ammunition
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $800

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
