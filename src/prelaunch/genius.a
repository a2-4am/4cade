!cpu 6502
!to "build/PRELAUNCH.INDEXED/GENIUS",plain
*=$106

    !source "src/macros.a"

         +READ_RAM2_WRITE_RAM2
         jsr   EnableAccelerator
         jsr   HideLaunchArtworkLC2
         +LOAD_FILE_AT genius_mb, $240
         lda   #$60
         sta   $333
         jsr   $300
         jmp   $240

genius_mb
         +PSTRING "PRELAUNCH/GENIUS.MB"

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
