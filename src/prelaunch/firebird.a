!cpu 6502
!to "build/PRELAUNCH.INDEXED/FIREBIRD",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $334b
         jsr   $3300      ; decompress
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$a5
         sta   $ae53      ; patch - don't decrease lives
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $b000

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
