!cpu 6502
!to "build/PRELAUNCH.INDEXED/SABOTAGE",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_AND_HIDE_ARTWORK_LC
         lda   #$60       ; hook1
         sta   $4020
         jsr   $4000      ; decompress1 and show title
         +DISABLE_ACCEL_LC

         ldx   #4
outer    ldy   #$C3       ; show title for 1 second before overwriting
middle   lda   #$FF
inner    sec
         sbc   #1
         bne   inner
         dey
         bne   middle
         dex
         bne   outer

         jsr   $6B00      ; decompress2 (overwrites title screen)

         lda   #$60       ; hook2
         sta   $1DB2
         jsr   $1D1F

         ; re-patch reset vector
         +RESET_VECTOR $100

         +GET_MACHINE_STATUS
         and   #CHEATS_ENABLED
         beq   +
         lda   #$60
         sta   $5BE6      ; patch - don't decrease ammo
+
         jmp   $42BC

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
