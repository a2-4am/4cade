!cpu 6502
!to "build/PRELAUNCH.INDEXED/ALIEN.DOWNPOUR",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $201f
         jsr   $2000      ; decompress
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$ad
         sta   $7699      ; patch - don't decrease lives
+
         +DISABLE_ACCEL_LC
         jmp   $73a0

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
