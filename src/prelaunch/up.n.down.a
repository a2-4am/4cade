!cpu 6502
!to "build/PRELAUNCH.INDEXED/UD",plain
*=$106

         !source "src/macros.a"

         +ENABLE_ACCEL_AND_HIDE_ARTWORK_LC
         lda   #<callback
         sta   $401B
         lda   #>callback
         sta   $401C
         jmp   $3004

callback
         jsr   $E26       ; load second stage
         +READ_RAM2_WRITE_RAM2
         jsr   DisableAccelerator
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$B5
         sta   $0912      ; patch - don't decrease lives
+
         ldx   #2
-        lda   reset, x
         sta   $77D5, x
         dex
         bpl   -
         stx   $22F       ; corrupt $3F4 to reboot
         stx   $2C4
         lda   #$D2       ; second reset vector
         sta   $2B4
         sta   $FFFC
         lda   #$77
         sta   $2BC
         sta   $FFFD

         jmp   $401D      ; continue to game

reset
         jmp   ($FFFC)    ; reboot

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
