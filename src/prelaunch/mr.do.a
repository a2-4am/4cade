!cpu 6502
!to "build/PRELAUNCH.INDEXED/MD",plain
*=$106

    !source "src/macros.a"

         +USES_TEXT_PAGE_2
         +NEW_RESET_VECTOR_64K $51
         clc
         bcc   cheat3

cheat2
         jsr   $20d

cheat64
         lda   #$a5
         sta   $1da7
         sta   $9bf
         rts

cheat1
         ldy   #<cheat2
         sty   $209
         ldy   #>cheat2
         sty   $20a
         bne   $19e

cheat3

         lda   #$60
         sta   $83e
         +HIDE_ARTWORK_LC
         jsr   $800

         +GET_MACHINE_STATUS_LC
         and   #CHEATS_ENABLED
         pha

+        lda   $846
         beq   cheat48

         lda   #$60
         sta   $d15
         jsr   $ce8

         pla
         beq   +

         lda   #<cheat4
         sta   $d137
         lda   #>cheat4
         sta   $d138

+        lda   #<fixgs
         sta   $89ee
         lda   #>fixgs
         sta   $89ef
         jmp   $d100

cheat4
         jsr   $d13b
         jmp   cheat64

cheat48
         pla
         beq   +
         lda   #<cheat1
         sta   $1040
         lda   #>cheat1
         sta   $1041
+        jmp   $1000

fixgs
         sei
         jmp   $08b2

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
