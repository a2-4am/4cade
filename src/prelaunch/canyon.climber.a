!cpu 6502
!to "build/PRELAUNCH.INDEXED/CANYON.CLIMBER",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $8005
         jsr   $6858      ; decompress
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$a5
         sta   $35c2
+
         ldx   #0
         stx   $3256      ; sets reset at $455
         inx
         stx   $3261      ; which is copied from $3255
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $3000

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
