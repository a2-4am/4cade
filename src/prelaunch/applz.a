!cpu 6502
!to "build/PRELAUNCH.INDEXED/APPLZ",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$4C
         sta   $841
         ldy   #0         ; Laser 128 compat
         jsr   $803       ; decompress
         +DISABLE_ACCEL
         jmp   $6000

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
