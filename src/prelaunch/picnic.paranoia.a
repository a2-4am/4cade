!cpu 6502
!to "build/PRELAUNCH.INDEXED/PICNIC.PARANOIA",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         ldx   #2
-        lda   reset, x
         sta   $9dbf, x
         dex
         bpl   -
         lda   #<callback-1
         sta   $450d
         lda   #>callback
         sta   $450a
         jmp   $4500

callback
         ldx   #0
         stx   $45e5
         inx
         stx   $45ea
         lda   #$A4
         sta   $45ef

         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         dec   $79B7      ; patch - don't decrease time
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $78fb

reset    jmp   $100

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
