!cpu 6502
!to "build/PRELAUNCH.INDEXED/SHFLPUCK",plain
*=$106

         !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $40B5
         jsr   $4000      ; decompress
         lda   #<callback
         sta   $A00A
         lda   #>callback
         sta   $A00B
         lda   #<callback2
         sta   $B1D4
         lda   #>callback2
         sta   $B1D5
         +READ_RAM2_WRITE_RAM2
         +LC_REBOOT
         +DISABLE_ACCEL_LC
         jmp   $A000

callback
         lda   #$88
         sta   $BF0E      ; bank in LC from now on
         jmp   $A8F3

callback2
         lda   $C051
         jmp   $A703

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
