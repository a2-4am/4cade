!cpu 6502
!to "build/PRELAUNCH.INDEXED/SHFLPUCK",plain
*=$106

         !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #%10000000
         sta   MONOCOLOR  ; force mono before title screen
         lda   #$60
         sta   $408E
         jsr   $4000      ; decompress
         lda   #<callback
         sta   $A00A
         lda   #>callback
         sta   $A00B
         +READ_RAM2_WRITE_RAM2
         +LC_REBOOT
         +DISABLE_ACCEL_LC
         jmp   $A000

callback
         lda   #$88
         sta   $BF0E      ; bank in LC from now on
         jmp   $A8F3

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
