!cpu 6502
!to "build/PRELAUNCH.INDEXED/NIGHT.STALKER",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$60
         sta   $5BD5
         jsr   $800       ; decompress
         jsr   $637       ; part 2

         sta   $6491
         lsr   $6496      ; reset vector patch

         +DISABLE_ACCEL_AND_HIDE_ARTWORK
         jsr   $6400
         +ENABLE_ACCEL
         lda   #$60
         sta   $634
         jsr   $606
         +GET_MACHINE_STATUS
         and   #CHEATS_ENABLED
         beq   +
         lda   #0
         sta   $1DEC      ; patch - don't increase lives
         sta   $13D0      ; patch - don't decrease lives
+
         +DISABLE_ACCEL
         jmp   $6000


!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
