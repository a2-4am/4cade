!cpu 6502
!to "build/PRELAUNCH.INDEXED/PUYO.PUYO",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_AND_HIDE_ARTWORK_LC
         inc   $3F4

         lda   #$4C
         sta   $7E76
         jsr   $6000      ; decompress

         jsr   DisableAccelerator
         sta   $C05E      ; fix //c color
         jmp   $7E7C

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
