!cpu 6502
!to "build/PRELAUNCH.INDEXED/MARBLE.MADNESS",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         inc   $3F4
         lda   #>(callback-1)
         sta   $4C76
         lda   #<(callback-1)
         sta   $4C79
         jmp   $4A53      ; decompress

callback
         inc   $8DDF      ; reset vector

         +GET_MACHINE_STATUS_LC_RW
         and   #CHEATS_ENABLED
         beq   +
         dec   $898F      ; patch - don't decrease time
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $1000

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
