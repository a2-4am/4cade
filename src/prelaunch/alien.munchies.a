!cpu 6502
!to "build/PRELAUNCH.INDEXED/ALIEN.MUNCHIES",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $1634
         ldy   #0
         jsr   $1613      ; decompress
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$ad
         sta   $10c9
         sta   $be8
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $833

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
