!cpu 6502
!to "build/PRELAUNCH.INDEXED/SS2",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         +NEW_RESET_VECTOR_64K $6D
         +READ_ROM_NO_WRITE
         lda   #$60
         sta   $DBE
         sta   $DE3
         jsr   $C24
         jsr   $BCFC      ; decompress
         +DISABLE_ACCEL_AND_HIDE_ARTWORK
         jsr   $DC1
         +ENABLE_ACCEL_LC
         jsr   $BCFC      ; decompress
         +DISABLE_ACCEL_LC
         jmp   $DE6

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
