!cpu 6502
!to "build/PRELAUNCH.INDEXED/VORTEX",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $407E
         jsr   $4000      ; decompress2
         +NEW_RESET_VECTOR $BFF0
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         dec   $EA8       ; patch - don't decrease lives
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $D566

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
