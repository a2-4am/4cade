!cpu 6502
!to "build/PRELAUNCH/GENIUS.MB",plain
*=$240

         !source "src/constants.a"   ; no code in these
         !source "src/macros.a"

         lda   #$4C
         sta   $41F9
         jsr   $4000      ; decompress
         +GET_MACHINE_STATUS
         and   #CHEATS_ENABLED
         pha
         lda   #$60
         sta   $429A
         lda   #<callback1
         sta   $422D
         lda   #>callback1
         sta   $422E
         jsr   $41FC
         pla
         beq   +
         dec   $1AFE      ; patch - don't decrease lives
         dec   $1B32      ; patch - don't increase lives
+
         +READ_RAM1_WRITE_RAM1
         lda   $6
         beq   ++
         ora   #$C0
         sta   $D4F1
         ldx   #0
-        ldy   $D600, x
         cpy   #$C4
         bne   +
         sta   $D600, x
+        ldy   $D700, x
         cpy   #$C4
         bne   +
         sta   $D700, x
+        inx
         bne   -
++
         lda   $C083
         +LC_REBOOT
         jsr   DisableAccelerator
         +READ_ROM_NO_WRITE
         jmp   $95E5

callback1
         lda   #$4C
         sta   $D7D0
         lda   #<callback2
         sta   $D7D1
         lda   #>callback2
         sta   $D7D2
         jmp   $D7BD

callback2
         sec
         sbc   #7
         cmp   #2
         bcc   +
         jmp   $D7DD
+        jmp   $D7D4
