!cpu 6502
!to "build/PRELAUNCH.INDEXED/BU",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$60
         sta   $9014
         sta   $9053
         jsr   $416c
         +DISABLE_ACCEL_AND_HIDE_ARTWORK
         lda   #$b1
         sta   $646b
         jsr   $6400
         +ENABLE_ACCEL_LC
         jsr   $811
         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$24
         sta   $a433
         sta   $96ea
         sta   $94d1
         sta   $9768
+
         ldx   #0
         stx   $A30A
         inx
         stx   $A30F      ; reset vector patch
         
         +DISABLE_ACCEL_LC
         jmp   $a300

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
