!cpu 6502
!to "build/PRELAUNCH.INDEXED/HANDY.DANDY",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC

         lda   #$60
         sta   $933C
         jsr   $7000      ; decompress
         lda   #1
         sta   $75DD      ; reset vector fix

         lda   MachineStatus
         and   #CHEATS_ENABLED
         beq   +
         lda   #$a5
         sta   $7165      ; patch - don't decrease lives
         sta   $72DC      ; patch - don't increase lives
         sta   $72E1      ; patch - don't increase lives
+
         +DISABLE_ACCEL_AND_HIDE_ARTWORK_LC
         jmp   $6000

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
