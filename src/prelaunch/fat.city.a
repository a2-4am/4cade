!cpu 6502
!to "build/PRELAUNCH.INDEXED/FAT.CITY",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$60
         sta   $9DF
         jsr   $800       ; load "DOS"
         lda   #$60
         sta   $B727
         jsr   $B700      ; load game
         lda   #$60
         sta   $8FA
         jsr   $800
         ldx   #1
         stx   $AA9C
         dex
         stx   $AAA1
         lda   #$A4
         sta   $AAA6      ; reset to $100

         +GET_MACHINE_STATUS_LC_RW
         and   #CHEATS_ENABLED
         beq   +
         lda   #$2C
         sta   $1330      ; patch - don't decrease fuel
         sta   $1339      ; patch - don't decrease fuel
         sta   $133C      ; patch - don't decrease fuel
         sta   $14BD      ; patch - don't decrease fuel
         sta   $938       ; patch - don't decrease fuel
+
         
         +DISABLE_ACCEL_LC
         jmp   $AA8F

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
