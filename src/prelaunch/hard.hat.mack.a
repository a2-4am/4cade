!cpu 6502
!to "build/PRELAUNCH.INDEXED/HARD.HAT.MACK",plain
*=$106

         !source "src/macros.a"

         +ENABLE_ACCEL_AND_HIDE_ARTWORK
         lda   #<patcher
         sta   $9431
         lda   #>patcher
         sta   $942E
         jsr   $4856      ; decompress
patcher  rts
         lda   #1
         sta   $2218      ; reset vector patch
         +GET_MACHINE_STATUS_LC_RW
         and   #CHEATS_ENABLED
         beq   +
         lda   #$ad
         sta   $50A5      ; patch - don't decrease lives
+

         +DISABLE_ACCEL
         lda   #$07
         pha
         lda   #$FF
         pha
         rts

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
