!cpu 6502
!to "build/PRELAUNCH.INDEXED/FLAK",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $6597
         sta   $6654
         jsr   $50C0       ; decompress
         +LOAD_FILE_AT flak_mb, $200
         jmp   $200

flak_mb
         +PSTRING "PRELAUNCH/FLAK.MB"

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
