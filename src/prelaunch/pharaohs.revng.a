!cpu 6502
!to "build/PRELAUNCH.INDEXED/PR",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$60
         sta   $3E8B
         jsr   $3C45      ; decompress

         lda   MachineStatus
         and   #CHEATS_ENABLED
         php
         jsr   DisableAccelerator
         jsr   HideLaunchArtworkLC2
         +LC_REBOOT
         lda   #$60
         sta   $864
         jsr   $867
         jsr   $84B
         plp
         beq   +
         lda   #$a5
         sta   $CF7       ; patch - don't decrease lives
+
         lda   #1
         sta   $AC6
         jmp   $A00

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
