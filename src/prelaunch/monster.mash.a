!cpu 6502
!to "build/PRELAUNCH.INDEXED/MONSTER.MASH",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL_AND_HIDE_ARTWORK
         lda   #$60
         sta   $9F6
         jsr   $800       ; load DOS
         +GET_MACHINE_STATUS_LC_RW
         and   #CHEATS_ENABLED
         beq   +
         lda   #<callback2
         sta   $BD07
         lda   #>callback2
         sta   $BD08
+
         lda   #<callback
         sta   $B748
         lda   #>callback
         sta   $B749
         +DISABLE_ACCEL_LC

         jmp   $B700

callback2
         pla
         pla
         jsr   $BD5A
         jsr   $BD09
         lda   $BEA3
         cmp   #5
         bne   +
         lda   $407
         cmp   #$21
         bne   +
         lda   $408
         bne   +
         lda   #$a5
         sta   $6625      ; patch - don't decrease lives
+
         clc
         rts

callback
         ldx   #0
         stx   $9E52
         inx
         stx   $9E53
         jmp   $9D84

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
