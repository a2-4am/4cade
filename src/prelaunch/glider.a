!cpu 6502
!to "build/PRELAUNCH.INDEXED/GLIDER",plain
*=$106

         !source "src/macros.a"

         +ENABLE_ACCEL_LC
         lda   #$60
         sta   $90C2
         jsr   $56FF      ; decompress
         +GET_MACHINE_STATUS_LC
         and   #CHEATS_ENABLED
         beq   +
         lda   #$AD
         sta   $D1B       ; don't decrease lives
+
         +DISABLE_ACCEL_LC
         jmp   $4100

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
