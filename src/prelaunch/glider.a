!cpu 6502
!to "build/PRELAUNCH.INDEXED/GLIDER",plain
*=$106

         !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #>(callback-1)
         sta   $6B49
         lda   #<(callback-1)
         sta   $6B4C
         jmp   $6B38      ; decompress

callback
         +GET_MACHINE_STATUS_LC
         and   #CHEATS_ENABLED
         beq   +
         lda   #$AD
         sta   $D1B       ; don't decrease lives
+
         +DISABLE_ACCEL_LC
         jmp   $4100

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
