!cpu 6502
!to "build/PRELAUNCH.INDEXED/ORBITRON",plain
*=$106

    !source "src/macros.a"

         +ENABLE_ACCEL
         lda   #$60
         sta   $2037
         jsr   $200C      ; decompress (don't show lores junk)
         lda   #$0C
         sta   $90FE      ; Laser 128 compat
         +DISABLE_ACCEL_AND_HIDE_ARTWORK
         lda   $C057
         lda   $C050
         jmp   $90D3

!if * > PrelaunchMax {
  !error "code is too large, ends at ", *
}
