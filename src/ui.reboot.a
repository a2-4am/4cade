;------------------------------------------------------------------------------
; OnQuit
; reboot system
;
; in:    none
; out:   nothing
;------------------------------------------------------------------------------
OnQuit
         jsr   SwitchToBank2
         jsr   EnableAcceleratorAndSwitchToBank1
PatchQuit
         +FORCE_REBOOT
         jmp   $100
